POSTGRES_DB=hiring
POSTGRES_USER=hiring
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg://hiring:change-me@db:5432/hiring

# Gates the Streamlit Admin tab (backup/restore/reset). UI-layer protection only — it does not
# authenticate the underlying /admin/* HTTP endpoints. See docs/DECISIONS.md.
ADMIN_PASSWORD=change-me

# Root logger level for the app service (DEBUG, INFO, WARNING, ERROR).
LOG_LEVEL=INFO
